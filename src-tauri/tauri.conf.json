{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "文件脱敏处理工具",
  "version": "1.0.0",
  "identifier": "com.chen.desensitization",
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "文件脱敏处理工具",
        "width": 1480,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "createUpdaterArtifacts": false
  }
}
